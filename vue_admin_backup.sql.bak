DROP TABLE IF EXISTS `xianggang`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `xianggang` (
  `year_month_day` varchar(255) DEFAULT NULL,
  `station_code` varchar(255) DEFAULT NULL,
  `max_temperature` varchar(255) DEFAULT NULL,
  `min_temperature` varchar(255) DEFAULT NULL,
  `avg_temperature` varchar(255) DEFAULT NULL,
  `precipitation` varchar(255) DEFAULT NULL,
  `rain_sum` varchar(255) DEFAULT NULL,
  `snow_sum` varchar(255) DEFAULT NULL,
  `max_continuous_wind_speed` varchar(255) DEFAULT NULL,
  `windgusts_max` varchar(255) DEFAULT NULL,
  `winddirection_dominant` varchar(255) DEFAULT NULL,
  `shortwave_radiation_sum` varchar(255) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;
