/// Current unified weather fact table used by the backend routes and SQL agent prompts.
model weather_data {
  station_code                String   @db.VarChar(50)
  granularity                 Int      @db.TinyInt
  record_time                 DateTime @db.DateTime(0)
  avg_temperature             Decimal? @db.Decimal(7, 2)
  relativehumidity_2m         Decimal? @db.Decimal(5, 2)
  rain_sum                    Decimal? @db.Decimal(8, 2)
  snow_sum                    Decimal? @db.Decimal(8, 2)
  max_continuous_wind_speed   Decimal? @db.Decimal(6, 2)
  windgusts_max               Decimal? @db.Decimal(6, 2)
  winddirection_dominant      Int?     @db.SmallInt
  shortwave_radiation_sum     Decimal? @db.Decimal(8, 2)
  create_time                 DateTime? @default(now()) @db.Timestamp(0)

  @@id([station_code, granularity, record_time])
}

/// Directory table used by download/query routes to map province-city to station_code and time coverage.
model weather_directory {
  id           Int       @id @default(autoincrement())
  province     String    @db.VarChar(50)
  city         String    @db.VarChar(50)
  station_code String    @default("UNKNOWN") @db.VarChar(50)
  granularity  Int       @db.TinyInt
  start_time   DateTime  @db.DateTime(0)
  end_time     DateTime  @db.DateTime(0)
  total_count  Int       @default(0)
  update_time  DateTime? @db.Timestamp(0)
  create_time  DateTime? @default(now()) @db.Timestamp(0)

  @@unique([province, city, station_code, granularity], map: "uk_prov_city_station_gran")
  @@index([province, city], map: "idx_province_city")
}

/// Station to province/city mapping used when syncing weather_directory metadata.
model station_info {
  station_code String    @db.VarChar(50)
  province     String    @db.VarChar(50)
  city         String    @db.VarChar(50)
  latitude     Decimal?  @db.Decimal(10, 8)
  longitude    Decimal?  @db.Decimal(11, 8)
  granularity  Int       @default(2) @db.TinyInt
  create_time  DateTime? @default(now()) @db.Timestamp(0)

  @@id([station_code, granularity])
}

