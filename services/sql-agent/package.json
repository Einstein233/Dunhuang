{
  "scripts": {
    "start": "npx ts-node src/server.ts",
    "dev": "npx ts-node src/server.ts",
    "server:start": "powershell -ExecutionPolicy Bypass -File ./server.ps1 start",
    "server:stop": "powershell -ExecutionPolicy Bypass -File ./server.ps1 stop",
    "server:restart": "powershell -ExecutionPolicy Bypass -File ./server.ps1 restart",
    "server:status": "powershell -ExecutionPolicy Bypass -File ./server.ps1 status"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.20.0",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2"
  }
}
